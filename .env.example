# Required
ANTHROPIC_API_KEY=sk-ant-...

# Git — your ai-memory repository
AI_MEMORY_REPO=git@github.com:youruser/ai-memory.git
GIT_DEPLOY_KEY_B64=           # base64 of SSH private key with write access: base64 -i ~/.ssh/id_ed25519

# Optional — paths
AI_MEMORY_LOCAL_DIR=/tmp/ai-memory   # where to clone ai-memory inside the container
AI_MEMORY_REPO_URL=https://github.com/youruser/ai-memory   # makes finding links clickable in Telegram notifications and web UI

# Optional — auth
AUTH_TOKEN=                    # bearer token protecting POST /runs (recommended for public deploys)

# Optional — personalization
OWNER_NAME=yourname            # your name, used in the implementation agent prompt
TARGET_PROJECTS=Project A,Project B,new project,none   # comma-separated list of your active projects

# Optional — GitHub API (increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=ghp_...

# Optional — YouTube Data API (uses official comments endpoint before yt-dlp fallback)
YOUTUBE_API_KEY=

# Optional — override path to run_pipeline.sh if not in default location
EXTRACT_SCRIPT_PATH=

# Optional — transcription quality (tiny/base/small/medium/large-v3, default: tiny)
# Recommended for Railway: base (better proper-noun recognition, ~2x CPU cost vs tiny)
WHISPER_MODEL=

# Optional — OCR sampling for on-screen text in videos
OCR_MAX_FRAMES=6
OCR_FRAME_INTERVAL_SEC=2

# Optional — YouTube comments captured per video (0-50, default: 0)
YOUTUBE_MAX_COMMENTS=5

# Optional — public Google Drive PDF/document extraction limits
GOOGLE_DRIVE_MAX_BYTES=26214400
PDF_MAX_PAGES=20
PDF_MAX_CHARS=20000

# Optional — Telegram owner intake
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_USER_ID=              # owner user ID; both chat and user are checked when configured
TELEGRAM_WEBHOOK_SECRET=
MEDIA_UPLOAD_DIR=/tmp/tech-radar-media
EXTRACTION_WORK_ROOT=/tmp/tech-radar-extraction # dedicated managed root for temporary extraction artifacts
RUN_STATE_DIR=/tmp/tech-radar-runs  # durable accepted-run state; use a persistent volume in production

# Optional — StockBot social-video analysis handoff
STOCKBOT_API_URL=              # e.g. https://stockbot.example.com
STOCKBOT_SERVICE_TOKEN=        # dedicated Radar -> StockBot bearer service token
STOCKBOT_CALLBACK_SECRET=      # shared HMAC-SHA256 secret for completion callbacks
STOCKBOT_DETAIL_BASE_URL=      # e.g. https://stocks.example.com/social-video
STOCKBOT_TIMEOUT_MS=10000      # bounded to 1-30000 ms
STOCKBOT_UPLOAD_SECRET=        # HMAC secret for short-lived direct browser upload tickets
STOCKBOT_UPLOAD_ALLOWED_ORIGINS= # exact comma-separated StockBot dashboard origins; no wildcard
ROUTER_MODEL=claude-haiku-4-5-20251001

# Runtime
PORT=3000

# Optional — public feed (portfolio integration)
# PUBLIC_FEED_ALLOWED_ORIGINS=https://your-site.dev,https://www.your-site.dev
# PUBLIC_SITE_RADAR_BASE=https://your-site.dev/radar
